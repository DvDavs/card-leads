# Copia este archivo a .env y completa las llaves. .env esta gitignored.

# Proveedor de vision para la etapa `extract`. Valores: gemini | openai
# Arrancamos solo con Gemini; openai es stub por ahora.
LLM_PROVIDER=gemini

# --- Gemini (Google AI Studio: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# Modelo barato de vision. "gemini-2.5-flash" es el id real del flash;
# "gemini-flash" a secas no es un id valido y la llamada daria 404.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.5
GEMINI_MAX_TOKENS=1000
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# --- OpenAI (stub, aun sin implementar) ---
OPENAI_API_KEY=
