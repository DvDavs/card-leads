# Copia este archivo a .env y completa las llaves. .env esta gitignored.

# Proveedor de vision para la etapa `extract`. Valores: gemini | openai
# Arrancamos solo con Gemini; openai es stub por ahora.
LLM_PROVIDER=gemini

# --- Gemini (Google AI Studio: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# Modelo barato de vision. "gemini-2.5-flash" es el id real del flash;
# "gemini-flash" a secas no es un id valido y la llamada daria 404.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.5
# Tokens de SALIDA. Una tarjeta con varios servicios necesita margen; con 1000
# el JSON se corta a la mitad (MAX_TOKENS). 2048 da aire de sobra.
GEMINI_MAX_TOKENS=2048
# gemini-2.5-* razonan ("thinking") gastando tokens de salida ANTES de escribir,
# lo que cortaba el JSON. La extraccion no lo necesita: 0 = thinking desactivado.
GEMINI_THINKING_BUDGET=0
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# --- OpenAI (stub, aun sin implementar) ---
OPENAI_API_KEY=

# --- Deploy (etapa `deploy`, publica dc/ y web/ en el droplet) ---
# IP o dominio del droplet.
DEPLOY_HOST=
# Usuario ssh. Default: root
DEPLOY_USER=
# Carpeta remota raiz donde vive cada leads/<slug>/. Default: /var/www/cards
DEPLOY_ROOT=
# Base de las URLs publicas, SIN slash final (ej. https://cards.kronet.app).
DEPLOY_BASE_URL=
# Ruta local a la llave privada dedicada al deploy (ver infra/README.md).
# Opcional: si falta, ssh usa su resolucion default de identidades.
DEPLOY_SSH_KEY=
